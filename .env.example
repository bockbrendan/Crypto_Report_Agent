# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── RAG (Supabase / PostgreSQL + pgvector) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require

# ── On-chain data ─────────────────────────────────────────────────────────────
GLASSNODE_API_KEY=
ETHERSCAN_API_KEY=
DUNE_API_KEY=

# ── Sentiment ─────────────────────────────────────────────────────────────────
LUNARCRUSH_API_KEY=
CRYPTOPANIC_API_KEY=

# ── Macro ─────────────────────────────────────────────────────────────────────
FRED_API_KEY=

# ── Market / Derivatives ──────────────────────────────────────────────────────
COINGLASS_API_KEY=

# ── Infrastructure (optional — falls back to in-memory if not set) ────────────
REDIS_URL=redis://localhost:6379
